# Capitaine Python - Configuration sécurisée
# Copiez ce fichier en .env et adaptez les valeurs

# Environnement (development, staging, production)
ENVIRONMENT=development

# Configuration de l'exécuteur de code
EXECUTOR_URL=http://piston:2000/api/v2/execute
USE_SECURE_EXECUTOR=true

# Limites de sécurité
MAX_CODE_LENGTH=5000
MAX_EXECUTION_TIME=10
MAX_MEMORY_USAGE=134217728

# Configuration CORS (séparez par des virgules)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_METHODS=GET,POST

# Base de données
DB_PATH=/data/progress.db

# Logging
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=true
ENABLE_SECURITY_LOGGING=true

# Mode debug (à désactiver en production!)
DEBUG_MODE=false

# Configuration de production (décommentez pour la production)
# ENVIRONMENT=production
# DEBUG_MODE=false
# LOG_LEVEL=WARNING
# ALLOWED_ORIGINS=https://votredomaine.com