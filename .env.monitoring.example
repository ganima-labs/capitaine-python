# Configuration Monitoring Capitaine Python
# Copiez ce fichier en .env.monitoring et adaptez les valeurs

# ================================
# NOTIFICATIONS
# ================================

# Telegram (optionnel - pour les alertes instantanées)
TELEGRAM_BOT_TOKEN=votre_bot_token_ici
TELEGRAM_CHAT_ID=votre_chat_id_ici

# Email (obligatoire - pour les alertes importantes)
ADMIN_EMAIL=admin@capitaine-python.com
EMAIL_USERNAME=votre_email@gmail.com
EMAIL_PASSWORD=votre_mot_de_passe_app
EMAIL_SMTP_HOST=smtp.gmail.com:587

# Slack (optionnel)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ================================
# SÉCURITÉ
# ================================

# Mot de passe Grafana
GRAFANA_ADMIN_PASSWORD=admin123

# Mot de passe Prometheus (basic auth)
PROMETHEUS_USERNAME=admin
PROMETHEUS_PASSWORD=prometheus123

# ================================
# CONFIGURATION MONITORING
# ================================

# Intervalle du watchdog (secondes)
WATCHDOG_INTERVAL=30

# URL du webhook Alertmanager
ALERT_WEBHOOK_URL=http://alertmanager:9093/api/v1/alerts

# ================================
# PERFORMANCE
# ================================

# Rétention des métriques Prometheus (jours)
PROMETHEUS_RETENTION_DAYS=30

# Taille maximale des logs par conteneur (MB)
LOG_MAX_SIZE=100

# ================================
# DÉVELOPPEMENT
# ================================

# Mode debug (true/false)
DEBUG_MODE=false

# Niveau de log (DEBUG/INFO/WARN/ERROR)
LOG_LEVEL=INFO